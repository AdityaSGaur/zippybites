# Ignore node_modules in root and every app
node_modules/
apps/**/node_modules/
server/node_modules/

# Ignore build/dist output (if you build)
apps/**/build/
apps/**/dist/
server/build/
server/dist/

# Ignore environment files (secrets!)
server/.env

# Ignore logs
*.log

# Ignore OS & Editor junk
.vscode/
.DS_Store
Thumbs.db

# Ignore test coverage
coverage/

# Keep lock files because this is monorepo → keep them for each workspace
# So do NOT ignore pnpm-lock.yaml — we want them for consistent installs

# Ignore others if needed
*.env.local
*.env.development.local
*.env.test.local